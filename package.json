{
  "name": "@nuria-tech/auth-sdk",
  "version": "1.1.0",
  "description": "Browser OAuth 2.0 Authorization Code + PKCE client SDK — redirect-only, no password flows",
  "license": "MIT",
  "author": "Nuria Tech",
  "keywords": [
    "auth",
    "oauth2",
    "pkce",
    "oidc",
    "authentication",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuria-tech/nuria-auth-sdk.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.js",
      "require": "./dist/angular.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0",
    "next": ">=13.0.0",
    "nuxt": ">=3.0.0",
    "react": ">=18",
    "rxjs": ">=7.8",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/common": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "21.2.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.3.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "happy-dom": "20.7.0",
    "prettier": "3.8.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rxjs": "7.8.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vue": "3.5.22"
  }
}
