{
  "name": "@nuria/auth-sdk",
  "version": "1.0.0",
  "description": "Nuria Authentication SDK",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "8.2.4",
    "typescript": "5.6.3",
    "vitest": "2.1.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
