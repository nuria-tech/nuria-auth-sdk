{
  "name": "@nuria-tech/auth-sdk",
  "version": "2.0.3",
  "description": "Browser OAuth 2.0 Authorization Code + PKCE client SDK with support for password, Google, and 2FA login flows",
  "license": "MIT",
  "author": "Nuria Tech",
  "keywords": [
    "auth",
    "oauth2",
    "pkce",
    "oidc",
    "authentication",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuria-tech/nuria-auth-sdk.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.js",
      "require": "./dist/angular.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:build": "vitest run tests/build-artifacts.spec.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0",
    "next": ">=13.0.0",
    "nuxt": ">=3.0.0",
    "react": ">=18",
    "rxjs": ">=7.8",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/common": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.0",
      "serialize-javascript": ">=7.0.5",
      "devalue": ">=5.6.4",
      "node-forge": ">=1.4.0",
      "picomatch": ">=4.0.4",
      "h3": ">=1.15.9",
      "happy-dom": ">=20.8.9",
      "brace-expansion": ">=2.0.3",
      "srvx": ">=0.11.13",
      "yaml": ">=2.8.3",
      "lodash": ">=4.18.0"
    }
  },
  "devDependencies": {
    "@angular/common": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "happy-dom": "^20.8.9",
    "next": "^16.2.2",
    "nuxt": "4.4.2",
    "prettier": "3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rxjs": "7.8.2",
    "tsup": "8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue": "^3.5.31"
  }
}
